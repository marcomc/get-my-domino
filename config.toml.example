# Copy this file to ~/.config/get-my-domino/config.toml or pass it with
# --config.
#
# The CLI reads one config file at a time.
# For every supported key, advanced site overrides, and maintenance knobs, see
# ./config.full.toml in this repository.

# General
verbose = false

# Output Paths
output_parent_dir = "~/Documents"
collection_dir_name = "domino"
# output_dir = "~/Documents/domino"
# Leave unset to keep issue audiobooks under output_dir/audiobooks.
# audiobook_output_dir = "~/Audiobooks/Domino"
feed_folder_name = "la-settimana-di-domino"

# Exports
export_formats = ["html", "txt"]

# Audio
# Leave empty to use the macOS System Voice configured in Accessibility >
# Spoken Content.
siri_voice = ""
audio_auto = false
audio_format = "m4a"

# Audiobooks
audiobook_auto = false
magazine_title = "Domino"
filename_separator = "-"
audiobook_name_format = "{magazine_slug}{sep}{year}{sep}{number}{sep}{title_slug}"

# Speech Normalization
speech_normalize_auto = false
speech_normalize_command = "codex"
# Leave empty to use the Codex CLI default model, or set one explicitly such
# as "gpt-5.5", "gpt-5.4-mini", or "gpt-5.3-codex-spark" when available.
speech_normalize_model = ""
speech_normalize_prompt_path = "~/.config/get-my-domino/speech-normalize-codex.txt"

# Authentication
auth_username = ""
auth_password = ""
auth_session_path = "~/.config/get-my-domino/session.json"
